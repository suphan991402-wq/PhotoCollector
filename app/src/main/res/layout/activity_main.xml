<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0E1116">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ส่งรูปทุกเครื่องเข้ากลุ่ม Telegram เดียวกัน"
            android:textColor="#9AA4B2"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="สถานะ…"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="#1A1F27"
            android:padding="14dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bot Token"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="123456:ABC-DEF..."
            android:textColorHint="#5A6472"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="#1A1F27"
            android:padding="14dp"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chat ID ของกลุ่ม (มักขึ้นต้น -100...)"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="-1001234567890"
            android:textColorHint="#5A6472"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="#1A1F27"
            android:padding="14dp"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="บันทึก และทดสอบส่งข้อความ"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="22dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1F27"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ส่งรูปใหม่อัตโนมัติ"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เจอรูปใหม่แล้วยิงเข้ากลุ่มเองทันที (ไม่ส่งรูปเก่า)"
                    android:textColor="#9AA4B2"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendAll"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ส่งรูปเก่าทั้งหมดในเครื่องเข้ากลุ่ม"
            android:textSize="17sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ส่งเข้ากลุ่มไปแล้วทั้งหมด: 0 รูป"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>
