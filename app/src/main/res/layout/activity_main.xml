<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0E1116">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ส่งรูปทุกเครื่องเข้ากลุ่ม Telegram เดียวกัน"
            android:textColor="#9AA4B2"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="สถานะ…"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="#1A1F27"
            android:padding="14dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ชื่อเครื่อง / Prefix (ไม่บังคับ)"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etPrefix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="เช่น แม่, ร้าน1, iPhone-แดง"
            android:textColorHint="#5A6472"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="#1A1F27"
            android:padding="14dp"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="จะขึ้นเป็นชื่อไฟล์ตอนส่ง เช่น &quot;แม่_IMG_0012.jpg&quot; เพื่อรู้ว่ารูปมาจากเครื่องไหน"
            android:textColor="#5A6472"
            android:textSize="11sp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="บันทึก และทดสอบส่งข้อความ"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="22dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1F27"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ส่งรูปใหม่อัตโนมัติ"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เจอรูปใหม่แล้วยิงเข้ากลุ่มเองทันที (ไม่ส่งรูปเก่า)"
                    android:textColor="#9AA4B2"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1F27"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ส่งแบบรูปพรีวิว (บีบอัด)"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ปิด = คุณภาพเต็ม (แนะนำ) · เปิด = ไฟล์เล็กลง Telegram บีบอัดเอง (รูปเกิน 10MB ส่งคุณภาพเต็มให้อัตโนมัติ)"
                    android:textColor="#9AA4B2"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPhotoMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendAll"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ส่งรูปเก่าทั้งหมดในเครื่องเข้ากลุ่ม"
            android:textSize="17sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickSend"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="เลือกรูปส่งเอง"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ส่งเข้ากลุ่มไปแล้วทั้งหมด: 0 รูป"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvLastSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ยังไม่เคยส่งสำเร็จ"
            android:textColor="#9AA4B2"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckUpdate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ตรวจสอบอัพเดท"
            android:textSize="14sp"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="v1"
            android:textColor="#5A6472"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
